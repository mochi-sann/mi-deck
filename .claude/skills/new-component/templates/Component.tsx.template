import { cva, type VariantProps } from "class-variance-authority";
import { cn } from "@/lib/utils";

const exampleVariants = cva("flex items-center gap-1", {
  variants: {
    size: {
      sm: "text-sm",
      md: "text-base",
      lg: "text-lg",
    },
  },
  defaultVariants: { size: "md" },
});

export interface ExampleProps extends VariantProps<typeof exampleVariants> {
  label: string;
  className?: string;
}

export function Example({ label, size, className }: ExampleProps) {
  return (
    <span className={cn(exampleVariants({ size }), className)}>{label}</span>
  );
}
